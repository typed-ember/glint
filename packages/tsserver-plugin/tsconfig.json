{
  "extends": "../../tsconfig.compileroptions.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",

    // ts server plugins need to be cjs; the inherited `module: Node16` setting
    // emits CommonJS because this package is `"type": "commonjs"`.
    "types": ["@types/node"]
  },
  "include": ["src"],
  "references": [{ "path": "../ember-tsc" }]
}
