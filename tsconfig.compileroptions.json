{
  "compilerOptions": {
    "target": "ES2020",
    // Node16 allows top-level `await`, which was also unflagged in Node 14.8
    "module": "Node16",
    "moduleResolution": "Node16",
    // changing this was necessary for WeakRef to be available (required/referenced in Volar)
    "lib": ["ES2021", "dom"],
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // added because lru-cache has incorrect types
    // (used by @babel/eslint-parser)
    "skipLibCheck": true,

    // new
    "allowSyntheticDefaultImports": true,

    // We intentionally leave `esModuleInterop` unset so it takes the default for
    // the configured `module` mode (`true` under Node16). Explicitly setting it
    // to `false` is deprecated as of TypeScript 6.0 (TS5107). The fs.readFileSync
    // monkeypatch in vscode/src/extension.ts does not depend on this setting: it
    // patches the module object obtained from a runtime `require('node:fs')`, not
    // the top-level `import * as fs`.

    "types": []
  }
}
